import re
import random
import string

teks = """anton@mail.com
budi@gmail.co.id
slamet@getnada.com
matahari@tokopedia.com"""

emails = re.findall(r'\S+@\S+', teks)

def password_random():
    karakter = string.ascii_letters + string.digits
    return ''.join(random.choice(karakter) for i in range(8))

for email in emails:
    username = email.split("@")[0]
    print(email, "username:", username, ", password:", password_random())
